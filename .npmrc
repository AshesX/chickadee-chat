# Recent official Node.js Windows builds are compiled with ThinLTO (lld-link),
# and node-gyp propagates that setting to native addon builds by default. On a
# machine with only standard MSVC Build Tools (no LLVM/lld-link), the
# LTO-related linker flags node-gyp then passes (e.g. -flto=thin,
# /opt:lldltojobs=N) make link.exe fail with LNK1117, breaking any native
# addon install (including @chickadee/process-loopback and node-addon-api's
# own self-check). Force it off — this has no effect on machines where it
# wasn't an issue, since it only ever disabled an optional link-time
# optimization for locally-built native addons.
enable_thin_lto=false
