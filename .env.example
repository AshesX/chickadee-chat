# Copy to `.env` to configure the desktop app. All values are optional.

# WebSocket URL of the signaling server. Use wss:// for internet play (TLS).
# CHICKADEE_SIGNALING_URL=ws://localhost:8080

# TURN relay for cross-NAT play. If unset, a best-effort free public TURN is
# used. For reliable play, point these at your own coturn / hosted TURN.
# Multiple URLs may be comma-separated.
# CHICKADEE_TURN_URL=turn:turn.example.com:3478
# CHICKADEE_TURN_USERNAME=your-username
# CHICKADEE_TURN_CREDENTIAL=your-credential

# Signaling server listen port (read by apps/signaling).
# PORT=8080
