# Copy to `.env` to configure the desktop app. All values are optional.

# WebSocket URL of the signaling server (wss:// = TLS, for internet play).
# Packaged builds default to the hosted server below; dev defaults to localhost.
# Set this to override either.
# CHICKADEE_SIGNALING_URL=wss://chickadee-signaling.onrender.com

# TURN relay for cross-NAT play. STUN alone (always on, two providers) covers
# most home networks; only a pair where BOTH sides sit behind symmetric NAT
# needs TURN. None is configured by default — point these at your own coturn
# or another hosted TURN provider. Multiple URLs may be comma-separated.
# CHICKADEE_TURN_URL=turn:turn.example.com:3478
# CHICKADEE_TURN_USERNAME=your-username
# CHICKADEE_TURN_CREDENTIAL=your-credential

# Signaling server listen port (read by apps/signaling).
# PORT=8080

# --- Private-deployment hardening (all optional; default = open server) ---
# Shared join secret: when set on the SERVER, every client must present a matching
# value or be rejected. Set the SAME value where the client reads its env (a .env
# beside the .exe, or a system env var) so the desktop app sends it on join.
# CHICKADEE_JOIN_SECRET=some-long-random-string

# Comma-separated Origin allowlist for the signaling WebSocket (server-side).
# The desktop client sends no Origin, so leave unset to allow all.
# CHICKADEE_ALLOWED_ORIGINS=https://example.com,https://app.example.com
